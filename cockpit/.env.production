# Production build config (committed — NOT secret).
# Points the sandbox's screenshot path at the live vision worker on the CDN
# Worker (uicockpit-kit → kit.uicockpit.com). Vite loads this in production-mode
# builds (npm run build) and it overrides the dev-only .env.local (localhost).
# The Anthropic key is NEVER here — it's a Worker secret (wrangler secret put).
VITE_SANDBOX_VISION_URL=https://kit.uicockpit.com/vision
