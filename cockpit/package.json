{
  "name": "cockpit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run verify:icons && npm run audit:tokens && npm run audit:type && npm run audit:cascade && npm run audit:parity && npm run audit:components && npm run audit:coverage && npm run audit:modifiers && npm run audit:provenance && npm run audit:controls && npm run audit:layout && npm run audit:inline && npm run audit:craft && npm run audit:state-edge && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:icons": "node scripts/verify-icons.mjs",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "audit:tokens:fix": "node scripts/audit-tokens.mjs --fix",
    "audit:type": "node scripts/audit-type.mjs",
    "audit:cascade": "node scripts/audit-cascade.mjs",
    "audit:parity": "node scripts/audit-parity.mjs",
    "audit:components": "node scripts/audit-components.mjs",
    "audit:coverage": "node scripts/audit-coverage.mjs",
    "audit:modifiers": "node scripts/audit-modifiers.mjs",
    "audit:provenance": "node scripts/scan-app-provenance.mjs",
    "audit:controls": "node scripts/audit-dead-controls.mjs",
    "audit:layout": "node scripts/audit-layout.mjs",
    "audit:inline": "node scripts/audit-structural-inline.mjs",
    "audit:craft": "node scripts/audit-craft.mjs",
    "audit:state-edge": "node scripts/audit-state-edge.mjs",
    "check": "node scripts/uicockpit-check.mjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "iconoir-react": "^7.11.0",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
