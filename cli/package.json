{
  "name": "uicockpit",
  "version": "0.5.0",
  "description": "The CLI of the UICockpit design system generator - apply and ENFORCE your generated design system in any codebase: generate -> apply -> check. The verifier nobody else ships.",
  "type": "module",
  "bin": {
    "uicockpit": "bin/uicockpit.mjs"
  },
  "exports": {
    "./check": "./src/check.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test \"test/*.test.mjs\""
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "css-variables",
    "shadcn",
    "tailwind",
    "linter",
    "conformance",
    "ai",
    "agent",
    "cli"
  ],
  "homepage": "https://uicockpit.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderKaan/uicockpit.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/AlexanderKaan/uicockpit/issues"
  },
